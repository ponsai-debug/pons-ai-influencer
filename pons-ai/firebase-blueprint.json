{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the studio user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "credits": { "type": "number", "description": "Google Cloud Credits balance" }
      },
      "required": ["uid", "email", "credits"]
    },
    "StudioImage": {
      "title": "Generated Image",
      "description": "A single generated image in the cloud gallery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "prompt": { "type": "string" },
        "location": { "type": "string" },
        "outfit": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["url", "userId", "timestamp"]
    },
    "PromptLog": {
      "title": "Generation Prompt Log",
      "description": "Archive of technical prompts used for generation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "prompt": { "type": "string" },
        "location": { "type": "string" },
        "outfit": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["prompt", "timestamp"]
    },
    "TopUpRequest": {
      "title": "Credit Top-Up Request",
      "description": "A request for more credits awaiting developer approval",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "displayName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User account documents"
    },
    "/users/{userId}/gallery/{imageId}": {
      "schema": "StudioImage",
      "description": "Collection of images generated by the user"
    },
    "/users/{userId}/prompts/{promptId}": {
      "schema": "PromptLog",
      "description": "Archive of prompts generated by the user"
    },
    "/topups/{requestId}": {
      "schema": "TopUpRequest",
      "description": "Global collection of credit top-up requests"
    }
  }
}
